<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header с кнопкой назад и картинкой -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="280dp">

        <ImageView
            android:id="@+id/foodImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Food" />

        <!-- Кнопка назад -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/home"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_margin="16dp"
            android:background="@android:color/white"
            android:contentDescription="Back" />

    </FrameLayout>

    <!-- CardView с закруглёнными углами для ScrollView -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="0dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">

        <!-- Основной контент -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Белая карточка с информацией -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Название блюда -->
                        <TextView
                            android:id="@+id/foodTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cacoa Maca Walnut Milk"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#2E3E5C"
                            android:layout_marginBottom="8dp" />

                        <!-- Категория и время готовки -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/foodDetails"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Food • 60 mins"
                                android:textSize="12sp"
                                android:textColor="#9FA5C0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="375 x 375"
                                android:textSize="10sp"
                                android:textColor="#FFFFFF"
                                android:background="#2196F3"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginStart="12dp" />
                        </LinearLayout>

                        <!-- Информация об авторе -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="16dp">

                            <androidx.cardview.widget.CardView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                app:cardCornerRadius="20dp">

                                <ImageView
                                    android:id="@+id/authorAvatar"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:contentDescription="Author" />
                            </androidx.cardview.widget.CardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/authorName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Elena Shelby"
                                    android:textSize="14sp"
                                    android:textColor="#2E3E5C"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Зелёная кнопка с лайками -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="20dp"
                                app:cardBackgroundColor="#4CAF50"
                                app:cardElevation="0dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="6dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="♥ 273 Likes"
                                        android:textSize="12sp"
                                        android:textColor="#FFFFFF"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Description -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2E3E5C"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your recipe has been uploaded, you can see it on your profile. Your recipe has been uploaded, you can see it on your profile."
                        android:textSize="12sp"
                        android:textColor="#9FA5C0"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <!-- Ingredients -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ingredients"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2E3E5C"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ 4 Eggs"
                        android:textSize="12sp"
                        android:textColor="#2E3E5C"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ 1/2 Butter"
                        android:textSize="12sp"
                        android:textColor="#2E3E5C"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ 1/2 Milk"
                        android:textSize="12sp"
                        android:textColor="#2E3E5C"
                        android:layout_marginBottom="16dp" />

                    <!-- Прогресс бар -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:background="#2C3E5F"
                        android:layout_marginBottom="16dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>