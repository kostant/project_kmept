<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Контейнер для фрагментов -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tabs_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Нижняя панель вкладок -->
    <LinearLayout
        android:id="@+id/tabs_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tab1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Рецепты"
            android:textSize="11sp"
            android:gravity="center"
            android:padding="6dp"
            android:drawableTop="@drawable/edit_active"
            android:drawablePadding="3dp"
            android:textColor="@color/tabActive" />

        <TextView
            android:id="@+id/tab2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Домой"
            android:textSize="11sp"
            android:gravity="center"
            android:padding="6dp"
            android:drawableTop="@drawable/home"
            android:drawablePadding="3dp"
            android:textColor="@color/tabInactive" />

        <TextView
            android:id="@+id/tab3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Уведомления"
            android:textSize="11sp"
            android:gravity="center"
            android:padding="6dp"
            android:drawableTop="@drawable/notification"
            android:drawablePadding="3dp"
            android:textColor="@color/tabInactive" />

        <TextView
            android:id="@+id/tab4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Профиль"
            android:textSize="11sp"
            android:gravity="center"
            android:padding="6dp"
            android:drawableTop="@drawable/profile"
            android:drawablePadding="3dp"
            android:textColor="@color/tabInactive" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
